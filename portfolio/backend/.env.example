# ============================================================
# Portfolio RAG backend — environment template
# Copy to `.env` and fill in the secrets. Single provider:
# OpenAI (chat + dense embeddings) + Pinecone (hybrid + rerank).
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Pinecone (dense + sparse indexes + hosted reranker) ---
PINECONE_API_KEY=
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DENSE_INDEX=portfolio-dense
PINECONE_SPARSE_INDEX=portfolio-sparse
PINECONE_RERANK_MODEL=bge-reranker-v2-m3

# --- Retrieval ---
DENSE_TOP_K=20
SPARSE_TOP_K=20
RERANK_TOP_N=5

# --- API / assistant ---
ALLOWED_ORIGINS=*
RATE_LIMIT=20/minute
# Conversation history pairs resent to the model each turn (token control).
MAX_HISTORY_PAIRS=3
ASSISTANT_NAME=Vatsal Vala
BOT_NAME=Anvi
CONTACT_EMAIL=vatsalvala46@gmail.com
